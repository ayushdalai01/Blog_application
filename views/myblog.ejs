<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>My Blogs</title>
    <style>
        .bottom-right-box {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 100px;
            padding: 15px;
            background-color: #4CAF50;
            color: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            font-family: Arial, sans-serif;
            text-align: center;
            z-index: 1000;
        }
    </style>
</head>
<body>

    <%- include('./partials/nav') %>

    <div class="container mt-4">

    <h2 class="mb-4 fw-bold">My Blogs (<%= blogs.length %>) </h2>

    <div class="row g-4">
        <% blogs.forEach(blog => { %>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">

                    <img
                        src="<%= blog.coverImage %>"
                        class="card-img-top"
                        alt="<%= blog.title %>"
                        style="height: 180px; object-fit: cover;"
                    >

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">
                            <%= blog.title %>
                        </h5>

                        <div class="mt-auto d-flex gap-2">

                            <a
                                href="/blog/<%= blog._id %>"
                                class="btn btn-primary flex-grow-1"
                            >
                                View
                            </a>

                            <a
                                href="/blog/edit/<%= blog._id %>"
                                class="btn btn-warning flex-grow-1"
                            >
                                Edit
                            </a>

                            <form
                                action="/user/myblog/<%= blog._id %>"
                                method="POST"
                                class="flex-grow-1"
                                onsubmit="return confirm('Delete this blog?')"
                            >
                                <button
                                    type="submit"
                                    class="btn btn-danger w-100"
                                >
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <a class = "bottom-right-box" href = "/blog/addnew"> + Add New </a>

</div>

    <%- include('./partials/scripts') %>

</body>
</html>