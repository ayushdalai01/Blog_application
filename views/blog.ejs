<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title> document </title>
</head>
<body>
    <%- include('./partials/nav') %>   
    <div class="container mt-4"> 
        <h1>
            <%= blog.title %>
        </h1>
        <img src = '<%= blog.coverImage %>' width="1000px"/>
        <pre>
            <%= blog.content %>
        </pre>
    </div>

    <div class="container mt-4">
        <img src="<%= blog.createdBy?.profileImageURL %>" 
        alt = 'Profile'
        onerror="this.onerror=null; this.src='/profile_pic.jpeg';"
        style="width: 40px; height: 40px; object-fit: cover;"
        /> 
        <%= blog.createdBy.fullName %>
    </div>

    <div class="container mt-3">
        <h1>
            Comments (<%= comments.length %>) 
        </h1>
        <% if(locals.user) { %>
        
            <form action="/blog/comment/<%= blog._id %>" method="post">
                    <div class="mb-3">
                        <input type="text" name = 'content' class = 'form-control' placeholder = 'enter your comment'/>
                    </div>
                    <button class = 'btn btn-sn btn-primary' type = 'submit'> Add </button>
                </form>
            <% } %>
        <div class="mt-3">
                <% comments.forEach((comment) => { %>
                    <div class="d-flex align-items-start gap-2 mb-3">
                        <img src="<%= comment.createdBy?.profileImageURL %>"
                             onerror="this.onerror=null; this.src='/profile_pic.jpeg';"
                             style="width: 40px; height: 40px; object-fit: cover;">
                        <div>
                            <strong><%= comment.createdBy?.fullName || 'User' %></strong>
                            <pre class="mb-0 mt-1" style="white-space: pre-wrap;"><%= comment.content %></pre>
                        </div>
                    </div>
                <% }) %>
            </div>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>